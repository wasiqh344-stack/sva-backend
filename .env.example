# ---- Server ----
PORT=3000
NODE_ENV=development

# Comma-separated list of origins allowed to call this API
# In production, set this to your real frontend domain, e.g. https://svadesign.com
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500

# ---- JWT (admin auth) ----
# Generate a long random string, e.g. `openssl rand -hex 32`
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ---- Gmail (Nodemailer) ----
# Use a Gmail "App Password", NOT your normal Gmail password.
# Create one at https://myaccount.google.com/apppasswords (2FA must be on)
GMAIL_USER=svadesign@gmail.com
GMAIL_APP_PASSWORD=your_16_character_app_password
NOTIFY_EMAIL=svadesign@gmail.com

# ---- Anthropic (Claude) chat widget ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6

# ---- Admin bootstrap (only used by scripts/create-admin.js) ----
ADMIN_EMAIL=admin@svadesign.com
ADMIN_PASSWORD=change_this_password

# Required as a header (x-signup-secret) to create NEW admin accounts via /api/admin/signup.
# Keeps random visitors from signing themselves up as admin. Change this to your own secret.
ADMIN_SIGNUP_SECRET=change_this_signup_secret
